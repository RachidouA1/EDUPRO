# =============================================================================
#  EDUPRO — Fichier de credentials pour la sauvegarde automatique
#  Copier ce fichier en ".db_credentials" et remplir les valeurs réelles
#  IMPORTANT : chmod 600 .db_credentials  (lecture root uniquement)
# =============================================================================

# ── Base de données ───────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=edupro
DB_USER=edupro_backup
DB_PASS=MOT_DE_PASSE_ICI

# ── Sauvegarde locale temporaire ──────────────────────────────────────────────
BACKUP_DIR=/tmp/edupro_backups

# ── Google Drive (rclone) ─────────────────────────────────────────────────────
GDRIVE_REMOTE=gdrive                # Nom du remote rclone (configuré via rclone config)
GDRIVE_FOLDER=EDUPRO_Backups        # Nom du dossier dans Google Drive

# ── Rétention ─────────────────────────────────────────────────────────────────
RETENTION_DAYS=30                   # Nombre de jours de sauvegardes à conserver
